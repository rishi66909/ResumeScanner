package com.resumescanner.service;

import com.resumescanner.dto.ScanRequestDTO;
import com.resumescanner.dto.ScanResponseDTO;
import com.resumescanner.entity.ResumeScan;
import com.resumescanner.repository.ResumeScanRepository;
import com.resumescanner.utils.ResumeParser;
import com.resumescanner.utils.TextProcessor;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.util.List;
import java.util.stream.Collectors;

@Service
public class ResumeService {

    private final ResumeScanRepository repository;
    private final ResumeParser resumeParser;
    private final KeywordService keywordService;
    private final MatchingService matchingService;
    private final TextProcessor textProcessor;

    public ResumeService(ResumeScanRepository repository,
                         ResumeParser resumeParser,
                         KeywordService keywordService,
                         MatchingService matchingService,
                         TextProcessor textProcessor) {
        this.repository = repository;
        this.resumeParser = resumeParser;
        this.keywordService = keywordService;
        this.matchingService = matchingService;
        this.textProcessor = textProcessor;
    }

    public ScanResponseDTO scanResume(ScanRequestDTO request) throws IOException {
        String resumeText;
        String fileName = "text-input";

        MultipartFile file = request.getResumeFile();
        if (file != null && !file.isEmpty()) {
            resumeText = resumeParser.parse(file);
            fileName = file.getOriginalFilename();
        } else if (request.getResumeText() != null && !request.getResumeText().isBlank()) {
            resumeText = request.getResumeText();
        } else {
            throw new IllegalArgumentException("Either a resume file or resume text must be provided.");
        }

        String cleanedResumeText = textProcessor.sanitize(resumeText);
        String jobDescription = request.getJobDescription();

        List<String> resumeKeywords = keywordService.extractKeywords(cleanedResumeText);
        List<String> jobKeywords = keywordService.extractFromJobDescription(jobDescription);

        double matchScore = matchingService.calculateMatchScore(resumeKeywords, jobKeywords);
        List<String> matched = matchingService.getMatchedKeywords(resumeKeywords, jobKeywords);
        List<String> missing = matchingService.getMissingKeywords(resumeKeywords, jobKeywords);

        ResumeScan scan = ResumeScan.builder()
                .fileName(fileName)
                .fileType(file != null ? getExtension(fileName) : "text")
                .resumeText(cleanedResumeText)
                .jobDescription(jobDescription)
                .matchScore(matchScore)
                .matchedKeywords(String.join(",", matched))
                .missingKeywords(String.join(",", missing))
                .build();

        ResumeScan saved = repository.save(scan);

        return ScanResponseDTO.builder()
                .id(saved.getId())
                .fileName(fileName)
                .matchScore(matchScore)
                .matchedKeywords(matched)
                .missingKeywords(missing)
                .extractedKeywords(resumeKeywords)
                .summary(buildSummary(matchScore, matched.size(), missing.size()))
                .scannedAt(saved.getScannedAt())
                .build();
    }

    public List<ScanResponseDTO> getAllScans() {
        return repository.findAllByOrderByScannedAtDesc().stream()
                .map(this::toDTO)
                .collect(Collectors.toList());
    }

    public ScanResponseDTO getScanById(Long id) {
        ResumeScan scan = repository.findById(id)
                .orElseThrow(() -> new RuntimeException("Scan not found with id: " + id));
        return toDTO(scan);
    }

    public void deleteScan(Long id) {
        if (!repository.existsById(id)) {
            throw new RuntimeException("Scan not found with id: " + id);
        }
        repository.deleteById(id);
    }

    private ScanResponseDTO toDTO(ResumeScan scan) {
        return ScanResponseDTO.builder()
                .id(scan.getId())
                .fileName(scan.getFileName())
                .matchScore(scan.getMatchScore())
                .matchedKeywords(splitKeywords(scan.getMatchedKeywords()))
                .missingKeywords(splitKeywords(scan.getMissingKeywords()))
                .scannedAt(scan.getScannedAt())
                .build();
    }

    private List<String> splitKeywords(String keywords) {
        if (keywords == null || keywords.isBlank()) return List.of();
        return List.of(keywords.split(","));
    }

    private String getExtension(String fileName) {
        if (fileName == null || !fileName.contains(".")) return "unknown";
        return fileName.substring(fileName.lastIndexOf('.') + 1);
    }

    private String buildSummary(double score, int matched, int missing) {
        String level = score >= 75 ? "Strong" : score >= 50 ? "Moderate" : "Weak";
        return String.format("%s match (%.1f%%). %d keywords matched, %d missing.", level, score, matched, missing);
    }
}